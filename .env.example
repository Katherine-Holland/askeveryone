# App
APP_ENV=dev
APP_NAME=askeveryone
LOG_LEVEL=INFO

# OpenAI (router + ranker + answering)
OPENAI_API_KEY=
OPENAI_ROUTER_MODEL=gpt-4o-mini
OPENAI_RANKER_MODEL=gpt-4o-mini
OPENAI_ANSWER_MODEL=gpt-4o-mini

# Perplexity
PERPLEXITY_API_KEY=
PERPLEXITY_BASE_URL=https://api.perplexity.ai
PERPLEXITY_MODEL=sonar-pro

# Grok (xAI)
GROK_API_KEY=
GROK_BASE_URL=https://api.x.ai
GROK_MODEL=grok-beta

# Claude (Anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# Gemini (Google)
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com
GEMINI_MODEL=gemini-1.5-pro

# LLaMA (future / optional provider)
LLAMA_BASE_URL=
LLAMA_API_KEY=
LLAMA_MODEL=meta-llama/Meta-Llama-3.1-70B-Instruct

# HuggingFace (optional)
HUGGINGFACE_API_KEY=
HUGGINGFACE_BASE_URL=https://api-inference.huggingface.co
HUGGINGFACE_MODEL=google/flan-t5-large

# Neon Postgres (SQLAlchemy URL)
DATABASE_URL=postgresql+psycopg://user:pass@host/db?sslmode=require

# ---- Billing / credits ----
# free logged-in allowance before credits are required
FREE_DAILY_LIMIT=5
CREDITS_PER_QUERY=1
ASSUMED_COST_PER_QUERY_USD=0.005

# hard caps (anti-rinse)
FREE_DAILY_CAP=5
PAID_DAILY_CAP=50

# token caps
MAX_TOKENS_FREE=350
MAX_TOKENS_PAID=800

# provider cooldown after 429/quota
PROVIDER_COOLDOWN_MINUTES=10

# ---- Stripe ----
# Server-side secret key (sk_test_...) and webhook secret (whsec_...)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Stripe price IDs -> credits mapping
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PLUS=
STRIPE_PRICE_POWER=

CREDITS_STARTER=200
CREDITS_PLUS=450
CREDITS_POWER=1200

# Your public base URL for links (magic link verify etc.)
APP_BASE_URL=https://seekle.io
