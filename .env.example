# App
APP_ENV=dev
APP_NAME=askeveryone
LOG_LEVEL=INFO

# OpenAI (router + ranker + optionally answering)
OPENAI_API_KEY=your_openai_key
OPENAI_ROUTER_MODEL=gpt-4o-mini
OPENAI_RANKER_MODEL=gpt-4o-mini
OPENAI_ANSWER_MODEL=gpt-4o-mini

# Perplexity
PERPLEXITY_API_KEY=your_perplexity_key
PERPLEXITY_BASE_URL=https://api.perplexity.ai
PERPLEXITY_MODEL=sonar-pro

# Grok (xAI)
GROK_API_KEY=your_grok_key
GROK_BASE_URL=https://api.x.ai
GROK_MODEL=grok-beta

# Claude (Anthropic)
ANTHROPIC_API_KEY=your_anthropic_key
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# Gemini (Google)
GEMINI_API_KEY=your_gemini_key
GEMINI_BASE_URL=https://generativelanguage.googleapis.com
GEMINI_MODEL=gemini-1.5-pro

# LLaMA (provider / OpenAI-compatible endpoint)
# Example model name varies by provider; set it to exactly what your provider docs show.
LLAMA_BASE_URL=https://<provider-base-url>/v1
LLAMA_API_KEY=your_provider_key
LLAMA_MODEL=meta-llama/Meta-Llama-3.1-70B-Instruct

# HuggingFace (optional)
HUGGINGFACE_API_KEY=your_hf_key
HUGGINGFACE_BASE_URL=https://api-inference.huggingface.co
HUGGINGFACE_MODEL=google/flan-t5-large

# Neon Postgres (SQLAlchemy URL)
DATABASE_URL=postgresql+psycopg://user:pass@host/db?sslmode=require

# pricing structure
FREE_DAILY_LIMIT=5
PAID_DAILY_LIMIT=50
MAX_TOKENS_FREE=500
MAX_TOKENS_PAID=2000
CREDITS_PER_QUERY=1

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_STARTER=
STRIPE_PRICE_ID_PLUS=
STRIPE_PRICE_ID_POWER=
APP_BASE_URL=https://seekle.ai
